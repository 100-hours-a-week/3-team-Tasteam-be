        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "(100 * (sum(rate(tasteam_api_request_total{job=\"spring\", environment=~\"$environment\", instance=~\"$instance\", domain=~\"$domain\", outcome=\"server_error\"}[5m])) / clamp_min(sum(rate(tasteam_api_request_total{job=\"spring\", environment=~\"$environment\", instance=~\"$instance\", domain=~\"$domain\"}[5m])), 0.00001))) or on() vector(0)",
          "refId": "A"
        }
      ],
      "title": "5xx Error Ratio",
      "type": "stat"
    },
    {
      "datasource": {
