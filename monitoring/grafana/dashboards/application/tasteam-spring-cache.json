      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (cache, result) (rate(tasteam_cache_requests_total{job=\"spring\", environment=~\"$environment\", instance=~\"$instance\", cache=~\"$cache\"}[5m]))",
          "legendFormat": "{{cache}} {{result}}",
          "refId": "A"
        }
