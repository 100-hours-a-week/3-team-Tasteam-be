          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "100 * (sum(increase(tasteam_cache_requests_total{job=\"spring\", environment=~\"$environment\", instance=~\"$instance\", cache=~\"$cache\", result=\"hit\"}[5m])) / clamp_min(sum(increase(tasteam_cache_requests_total{job=\"spring\", environment=~\"$environment\", instance=~\"$instance\", cache=~\"$cache\"}[5m])), 1))",
          "refId": "A"
        }
      ],
      "title": "Cache Hit Ratio",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
