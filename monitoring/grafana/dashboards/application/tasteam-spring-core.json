          "expr": "count(count by (__name__) ({job=\"spring\", environment=~\"$environment\", instance=~\"$instance\", __name__=~\"tasteam_.*|executor_.*|notification_.*|analytics_.*|outbox_.*|ws_.*|mq_.*|mail_send_request_count|rate_limited_count|redis_errors_count\"}))",
