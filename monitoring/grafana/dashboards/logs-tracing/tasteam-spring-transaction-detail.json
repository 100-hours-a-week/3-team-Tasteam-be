          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "hideZeros": false,
          "mode": "multi",
          "sort": "none"
        }
      },
      "pluginVersion": "11.6.0",
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (domain) (rate(tasteam_api_request_total{job=\"spring\", environment=~\"$env\", instance=~\"$instance\", domain=~\"$domain\", method=~\"$method\", outcome=~\"$api_outcome\"}[1m]))",
          "exemplar": false,
          "legendFormat": "{{domain}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "RPS by Domain (도메인별 RPS)",
      "type": "timeseries"
    },
