# `.env` 파일을 복사해서 값 채우세요.
#
# `dev`/`prod` 실행 시 `.env`를 읽습니다.
#
# Admin
ADMIN_USERNAME=
ADMIN_PASSWORD=
#
# Local Dev Infra (docker-compose.dev-infra.yml)
DEV_DB_NAME=
DEV_DB_PORT=5432
#
# 데이터베이스 (JDBC)
DB_URL=jdbc:postgresql://localhost:5432/tasteam
DB_USERNAME=db_user_name_example
DB_PASSWORD=db_password_example
#
# FLYWAY
DB_FLYWAY_USER=db_user_name_example
DB_FLYWAY_PASSWORD=db_password_example
#
# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
#
# Message Queue (shared platform)
MQ_ENABLED=true
MQ_PROVIDER=kafka
MQ_TOPIC_PREFIX=tasteam
MQ_DEFAULT_CONSUMER_GROUP=tasteam-api
MQ_POLL_TIMEOUT_MILLIS=1000
MQ_MAX_RETRIES=3

# Kafka (shared platform)
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_CONNECT_URL=http://localhost:8083
KAFKA_CLIENT_ID=tasteam-api
KAFKA_PRODUCER_ACKS=all
KAFKA_PRODUCER_RETRIES=3
KAFKA_PRODUCER_BATCH_SIZE=16384
KAFKA_PRODUCER_LINGER_MS=5
KAFKA_PRODUCER_SEND_TIMEOUT_MILLIS=5000
KAFKA_CONSUMER_CONCURRENCY=1
KAFKA_CONSUMER_MAX_POLL_RECORDS=500
KAFKA_CONSUMER_POLL_TIMEOUT_MILLIS=1000
KAFKA_CONSUMER_RETRY_MAX_ATTEMPTS=3
KAFKA_CONSUMER_RETRY_BACKOFF_MILLIS=1000

# Message Queue (domain-specific)
ANALYTICS_EVENT_LOG_TOPIC=evt.analytics.event-log.v1
ANALYTICS_EVENT_LOG_CONSUMER_GROUP=cg.analytics.event-log.v1
ANALYTICS_EVENT_LOG_DLQ_TOPIC=evt.analytics.event-log.v1.dlq

NOTIFICATION_MQ_TOPIC=evt.notification.dispatch.v1
NOTIFICATION_MQ_CONSUMER_GROUP=cg.notification.processor.v1
NOTIFICATION_MQ_DLQ_TOPIC=evt.notification.dispatch.v1.dlq

USER_ACTIVITY_MQ_TOPIC=evt.user-activity.ingest.v1
USER_ACTIVITY_MQ_CONSUMER_GROUP=cg.user-activity.ingest.v1
USER_ACTIVITY_MQ_DLQ_TOPIC=evt.user-activity.ingest.v1.dlq
#
# JWT
JWT_SECRET=change-me
JWT_ACCESS_TOKEN_EXPIRATION=1800000
JWT_REFRESH_TOKEN_EXPIRATION=1209600000

# OAuth2 (선택)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# Domain
SERVICE_DOMAIN=https://tasteam.kr
API_DOMAIN=https://api.tasteam.kr

# Storage (S3)
STORAGE_TYPE=s3
STORAGE_REGION=
STORAGE_BUCKET=
ANALYTICS_BUCKET=
STORAGE_BASE_URL=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_PRESIGNED_EXPIRATION_SECONDS=300
STORAGE_TEMP_UPLOAD_PREFIX=uploads/temp

# S3 Sink Connector (Kafka Connect 컨테이너 + Spring 커넥터 자동 등록용)
# ANALYTICS_BUCKET과 별개: Kafka Connect S3 Sink가 직접 참조하는 버킷명
ANALYTICS_S3_BUCKET=tasteam-analytics-local
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# MinIO (로컬 S3 에뮬레이터)
# 로컬 통합 테스트 시 docker-compose.kafka.yml에서 기동
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Kafka Connect 커넥터 자동 등록
# 로컬 통합 테스트 시 true로 설정 (Spring 기동 시 커넥터 자동 등록)
KAFKA_CONNECT_CONNECTOR_AUTO_REGISTER=true
# 애플리케이션 자체 S3 클라이언트 endpoint. 로컬 API 직접 실행 시 http://localhost:9000
S3_ENDPOINT=http://localhost:9000
# Kafka Connect 커넥터용 endpoint. 로컬 통합 테스트 시 http://minio:9000 (Docker 내부)
KAFKA_CONNECT_S3_ENDPOINT=http://minio:9000
# MinIO 로컬: true, 운영: false
S3_PATH_STYLE_ACCESS=true

# File cleanup
FILE_CLEANUP_TTL_SECONDS=86400
FILE_CLEANUP_FIXED_DELAY_MS=3600000

# File upload policy
FILE_UPLOAD_MIN_SIZE_BYTES=1
FILE_UPLOAD_MAX_SIZE_BYTES=10485760
FILE_UPLOAD_ALLOWED_CONTENT_TYPES=image/jpeg,image/jpg,image/png,image/webp

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOWED_HEADERS=Authorization,Content-Type,Accept
CORS_EXPOSED_HEADERS=Authorization
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS


# Map
NAVER_MAPS_API_KEY_ID=
NAVER_MAPS_API_KEY=

# Webhook Configuration (Error Monitoring)
WEBHOOK_ENABLED=false
WEBHOOK_PROVIDER=discord
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# Webhook Retry Configuration
WEBHOOK_RETRY_MAX=3
WEBHOOK_RETRY_BACKOFF=1000

# Webhook Filter Configuration (Optional)
WEBHOOK_MIN_HTTP_STATUS=500
WEBHOOK_EXCLUDE_ERROR_CODES=

# Email (AWS SES)
NOTIFICATION_EMAIL_PROVIDER=ses
NOTIFICATION_EMAIL_SES_REGION=ap-northeast-2
NOTIFICATION_EMAIL_SES_ACCESS_KEY=
NOTIFICATION_EMAIL_SES_SECRET_KEY=
NOTIFICATION_EMAIL_SES_FROM_ADDRESS=no-reply@tasteam.co.kr

# Firebase Admin (FCM)
FIREBASE_ENABLED=
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Sentry (에러 추적)
SENTRY_DSN=

# Phase 3: 분산 트레이싱 (Grafana Tempo 준비 후 활성화)
TRACING_ENABLED=false
OTEL_ENDPOINT=
